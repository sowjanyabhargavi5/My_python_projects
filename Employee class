#EMPLOYEE CLASS

class Employee:

    def __init__(self,name,salary):

        self.name=name
        self.salary=salary

    def display(self):

        print("Employee Name:",self.name)
        print("Salary:",self.salary)

employee1=Employee("Bhargavi",25000)

employee1.display()

##output given by the vscode:
Employee Name: Bhargavi
Salary: 25000
