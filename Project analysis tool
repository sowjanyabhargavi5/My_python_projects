# Number Analysis Tool

def square(num):
    return num * num

def cube(num):
    return num * num * num

def even_or_odd(num):
    if num % 2 == 0:
        return "Even"
    else:
        return "Odd"

number = int(input("Enter a number: "))

print("\n===== NUMBER ANALYSIS =====")
print("Square:", square(number))
print("Cube:", cube(number))
print("Type:", even_or_odd(number))

