#PRODUCT INVENTORY

products=[]

for i in range(3):

    name=input("Enter product name: ")
    price=int(input("Enter product price: "))

    product=(name,price)

    products.append(product)

print("\nProduct List")

for product in products:
    print(product)

print("\nProducts Above 100")

for name,price in products:

    if price>100:
        print(name)

