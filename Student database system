# STUDENT DATABASE SYSTEM
# =====================================

students = {
    "Rahul": 85,
    "Anjali": 92,
    "Kiran": 76,
    "Bhargavi": 95
}

name = input("Enter student name: ")

if name in students:

    marks = students[name]

    print("Marks :", marks)

    if marks >= 90:
        print("Grade : A")
    elif marks >= 75:
        print("Grade : B")
    else:
        print("Grade : C")

else:
    print("Student Not Found")

print("\nProgram Completed Successfully!")


