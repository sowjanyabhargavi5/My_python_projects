# EVEN OR ODD CHECKER
# =====================================

print("EVEN OR ODD CHECKER\n")

number = int(input("Enter a number: "))

if number % 2 == 0:
    print(number, "is Even")
else:
    print(number, "is Odd")

print("\nProgram Completed Successfully!")


