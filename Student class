#STUDENT CLASS

class Student:

    def __init__(self,name,marks):

        self.name=name
        self.marks=marks

    def display(self):

        print("Name:",self.name)
        print("Marks:",self.marks)

student1=Student("Bhargavi",95)

student1.display()


##output given by the vscode:
Name: Bhargavi
Marks: 95
